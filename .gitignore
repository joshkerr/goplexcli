# OS
.DS_Store
Thumbs.db

# Desktop GUI (Wails). The frontend build output (dist) is generated by
# `wails build` / `npm run build`; only a .gitkeep is tracked so the go:embed
# directive still compiles on a fresh clone.
gui/frontend/node_modules/
gui/build/bin/
# Keep Wails application artwork while ignoring generated build products.
!gui/build/
gui/build/*
!gui/build/appicon.png
!gui/build/gen_icons.py
!gui/build/windows/
gui/build/windows/*
!gui/build/windows/icon.ico
gui/frontend/dist/*
!gui/frontend/dist/.gitkeep
# Wails-generated JS bindings (regenerated on each build; the frontend uses its
# own thin wrapper in src/lib/api.ts instead of importing these).
gui/frontend/wailsjs/

gui/frontend/package.json.md5
/goplexcli-preview
